<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:kando_desktop.Resources.Strings"
             xmlns:components="clr-namespace:kando_desktop.Views.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:kando_desktop"
             Shell.NavBarIsVisible="False"
             x:Class="kando_desktop.Views.ContentPages.ModifyProfilePage">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <HorizontalStackLayout Grid.Row="0"
                               HorizontalOptions="Start"
                               Margin="10">

            <Border Style="{StaticResource InputBorderStyle}"
                    Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                    Padding="5"
                    HeightRequest="36"
                    WidthRequest="36"
                    StrokeShape="RoundRectangle 50"
                    local:CursorBehavior.Cursor="Hand">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackHome}"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding BackIconSource}"
                       HeightRequest="20"
                       WidthRequest="20"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>
            </Border>
        </HorizontalStackLayout>

        <Grid Grid.Row="1">

        </Grid>

        <Grid InputTransparent="True"
              VerticalOptions="End"
              HorizontalOptions="End"
              Margin="0,0,30,30">
            <components:ToastView x:Name="NotificationToast"/>
        </Grid>
    </Grid>
</ContentPage>
