<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:kando_desktop.Resources.Strings"
             xmlns:components="clr-namespace:kando_desktop.Views.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:kando_desktop"
             xmlns:controls="clr-namespace:kando_desktop.Controls"
             Shell.NavBarIsVisible="False"
             x:Class="kando_desktop.Views.ContentPages.VerifyCodePage">

    <Grid>
        <Grid RowDefinitions="Auto, *"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Slate900}}">

            <HorizontalStackLayout Grid.Row="0"
                                   HorizontalOptions="Start"
                                   Margin="20,10,20,0">

                <Border Style="{StaticResource InputBorderStyle}"
                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                        Padding="5"
                        HeightRequest="36"
                        WidthRequest="36"
                        StrokeShape="RoundRectangle 50"
                        local:CursorBehavior.Cursor="Hand">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,0"
                                Radius="7"
                                Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Border.GestureRecognizers>
                    <Image Source="{Binding BackIconSource}"
                           HeightRequest="20"
                           WidthRequest="20"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Border>
            </HorizontalStackLayout>

            <Grid Grid.Row="1"
                  VerticalOptions="Center"
                  HorizontalOptions="Center">
                <StackLayout>

                    <Border StrokeThickness="0"
                            Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                            BackgroundColor="{AppThemeBinding Light=#fcfcfc, Dark=#172133}"
                            StrokeShape="RoundRectangle 10"
                            Padding="50">
                        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">

                            <Border Grid.Row="0"
                                    Margin="0,0,0,20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    StrokeShape="RoundRectangle 8"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    BackgroundColor="{AppThemeBinding Light=#c3d9fd, Dark=#1a315c}"
                                    Stroke="{AppThemeBinding Light=#c3d9fd, Dark=#1a315c}">
                                <Image Source="menu.png"
                                       Aspect="Fill"
                                       WidthRequest="30"
                                       HeightRequest="30"/>
                            </Border>

                            <Label Grid.Row="1"
                                   HorizontalOptions="Center"
                                   Text="{x:Static strings:AppResources.VerifyIdentity}"
                                   Style="{StaticResource TitleHuge}"/>

                            <Label Grid.Row="2"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"
                                   Margin="0,10,0,20">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{x:Static strings:AppResources.EnterCode}"
                                              Style="{StaticResource SubtitleMuted}"
                                              FontSize="14"/>
                                        <Span Text=" "/>
                                        <Span Text="{Binding Email}"
                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"
                                              FontAttributes="Bold"
                                              FontSize="14"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <HorizontalStackLayout Grid.Row="3"
                                                   HorizontalOptions="Center"
                                                   Spacing="10"
                                                   Margin="0,10,0,20">

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry1}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry1"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry2}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry2"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry3}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry3"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry4}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry4"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry5}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry5"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                                <Border Style="{StaticResource InputBorderStyle}"
                                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                                        WidthRequest="45"
                                        HeightRequest="55"
                                        Padding="0,8"
                                        StrokeShape="RoundRectangle 8">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference CodeEntry6}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="2"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <controls:BorderlessEntry x:Name="CodeEntry6"
                                                              Keyboard="Numeric"
                                                              MaxLength="2"
                                                              FontSize="18"
                                                              HorizontalTextAlignment="Center"
                                                              VerticalTextAlignment="Center"
                                                              VerticalOptions="Center"
                                                              Margin="0"
                                                              TextChanged="OnCodeTextChanged"
                                                              BackgroundColor="Transparent"
                                                              TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"/>
                                </Border>

                            </HorizontalStackLayout>

                            <Button Grid.Row="4"
                                    Text="{x:Static strings:AppResources.VerifyCode}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding VerifyCommand}"
                                    local:CursorBehavior.Cursor="Hand"
                                    Margin="0,10,0,0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="Text"
                                                Value="{x:Static strings:AppResources.Sending}"/>
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                        <Setter Property="Opacity"
                                                Value="0.5"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding CanSend}"
                                                 Value="False">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                        <Setter Property="Opacity"
                                                Value="0.5"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <HorizontalStackLayout Grid.Row="5"
                                                   HorizontalOptions="Center"
                                                   Spacing="7"
                                                   Margin="0,15,0,0">
                                <Label Text="{x:Static strings:AppResources.NoCode}"
                                       Style="{StaticResource SubtitleMuted}"
                                       FontSize="14"
                                       VerticalOptions="Center"/>

                                <Label Text="{Binding ResendText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       local:CursorBehavior.Cursor="Hand">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding CanResend}"
                                                     Value="True">
                                            <Setter Property="TextColor"
                                                    Value="#3a7fef"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding CanResend}"
                                                     Value="False">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light={StaticResource Slate400}, Dark={StaticResource Slate500}}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ResendCommand}"/>
                                        <PointerGestureRecognizer PointerEntered="OnResendPointerEntered"
                                                                  PointerExited="OnResendPointerExited"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>
                </StackLayout>
            </Grid>
        </Grid>

        <Grid InputTransparent="True"
              VerticalOptions="End"
              HorizontalOptions="End"
              Margin="0,0,30,30">
            <components:ToastView x:Name="NotificationToast"/>
        </Grid>
    </Grid>
</ContentPage>