<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:kando_desktop.Resources.Strings"
             xmlns:components="clr-namespace:kando_desktop.Views.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:local="clr-namespace:kando_desktop"
             xmlns:controls="clr-namespace:kando_desktop.Controls"
             Shell.NavBarIsVisible="False"
             x:Class="kando_desktop.Views.ContentPages.ResetPasswordPage">

    <Grid>
        <Grid RowDefinitions="Auto, *"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Slate900}}">

            <HorizontalStackLayout Grid.Row="0"
                                   HorizontalOptions="Start"
                                   Margin="20,10,20,0">

                <Border Style="{StaticResource InputBorderStyle}"
                        Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}"
                        Padding="5"
                        HeightRequest="36"
                        WidthRequest="36"
                        StrokeShape="RoundRectangle 50"
                        local:CursorBehavior.Cursor="Hand">
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,0"
                                Radius="7"
                                Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Border.GestureRecognizers>
                    <Image Source="{Binding BackIconSource}"
                           HeightRequest="20"
                           WidthRequest="20"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Border>
            </HorizontalStackLayout>

            <Grid Grid.Row="1"
                  VerticalOptions="Center"
                  HorizontalOptions="Center">
                <StackLayout>

                    <Border StrokeThickness="0"
                            Stroke="{AppThemeBinding Light={StaticResource Slate200}, Dark={StaticResource BorderDark}}"
                            BackgroundColor="{AppThemeBinding Light=#fcfcfc, Dark=#172133}"
                            StrokeShape="RoundRectangle 10"
                            Padding="50">
                        <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">

                            <Border Grid.Row="0"
                                    Margin="0,0,0,20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    StrokeShape="RoundRectangle 8"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    BackgroundColor="{AppThemeBinding Light=#c3d9fd, Dark=#1a315c}"
                                    Stroke="{AppThemeBinding Light=#c3d9fd, Dark=#1a315c}">
                                <Image Source="padlock_blue.png"
                                       Aspect="Fill"
                                       WidthRequest="30"
                                       HeightRequest="30"/>
                            </Border>

                            <Label Grid.Row="1"
                                   HorizontalOptions="Center"
                                   Text="{x:Static strings:AppResources.CreateNewPassword}"
                                   Style="{StaticResource TitleHuge}"/>

                            <Label Grid.Row="2"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   Text="{x:Static strings:AppResources.NewPasswordDifferent}"
                                   Style="{StaticResource SubtitleMuted}"
                                   FontSize="14"
                                   Margin="0,10"/>

                            <VerticalStackLayout Spacing="5"
                                                 Grid.Row="3"
                                                 Margin="0,30,0,20">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0"
                                           Text="{x:Static strings:AppResources.NewPassword}"
                                           Style="{StaticResource FormLabel}"
                                           TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding NewPasswordErrorText}"
                                           IsVisible="{Binding HasNewPasswordError}"
                                           TextColor="#ef4444"
                                           FontSize="12"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="End"
                                           LineBreakMode="WordWrap"
                                           MaximumWidthRequest="180"/>
                                </Grid>
                                <Border Style="{StaticResource InputBorderStyle}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference PasswordEntry}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding HasNewPasswordError}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="#ef4444"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="1"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Image Grid.Column="0"
                                               Source="locked_computer.png"
                                               Style="{StaticResource InputIcon}"/>
                                        <controls:BorderlessEntry x:Name="PasswordEntry"
                                                                  Grid.Column="1"
                                                                  Text="{Binding NewPassword}"
                                                                  Placeholder="***********"
                                                                  PlaceholderColor="{AppThemeBinding Light={StaticResource Slate400}, Dark={StaticResource Slate500}}"
                                                                  TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"
                                                                  IsPassword="{Binding IsNewPasswordHidden}"
                                                                  BackgroundColor="Transparent"
                                                                  VerticalOptions="Center"
                                                                  HeightRequest="40"
                                                                  Margin="-5,0"
                                                                  ReturnType="Go"
                                                                  ReturnCommand="{Binding ResetPasswordCommand}">
                                            <controls:BorderlessEntry.Behaviors>
                                                <toolkit:EventToCommandBehavior EventName="Unfocused"
                                                                                Command="{Binding ValidatePasswordCommand}"/>
                                            </controls:BorderlessEntry.Behaviors>
                                        </controls:BorderlessEntry>
                                        <ImageButton Grid.Column="2"
                                                     Source="{Binding NewEyeIconSource}"
                                                     Command="{Binding ToggleNewPasswordVisibilityCommand}"
                                                     HeightRequest="40"
                                                     WidthRequest="40"
                                                     BackgroundColor="Transparent"
                                                     local:CursorBehavior.Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5"
                                                 Grid.Row="4"
                                                 Margin="0,0,0,20">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0"
                                           Text="{x:Static strings:AppResources.ConfirmNewPassword}"
                                           Style="{StaticResource FormLabel}"
                                           TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding ConfirmNewPasswordErrorText}"
                                           IsVisible="{Binding HasConfirmNewPasswordError}"
                                           TextColor="#ef4444"
                                           FontSize="12"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="End"
                                           LineBreakMode="WordWrap"
                                           MaximumWidthRequest="180"/>
                                </Grid>
                                <Border Style="{StaticResource InputBorderStyle}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Slate50}, Dark={StaticResource Slate800}}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Source={x:Reference ConfirmNewPasswordEntry}, Path=IsFocused}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Blue500}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding HasConfirmNewPasswordError}"
                                                     Value="True">
                                            <Setter Property="Stroke"
                                                    Value="#ef4444"/>
                                            <Setter Property="StrokeThickness"
                                                    Value="1"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Image Grid.Column="0"
                                               Source="locked_computer.png"
                                               Style="{StaticResource InputIcon}"/>
                                        <controls:BorderlessEntry x:Name="ConfirmNewPasswordEntry"
                                                                  Grid.Column="1"
                                                                  Text="{Binding ConfirmNewPassword}"
                                                                  Placeholder="***********"
                                                                  PlaceholderColor="{AppThemeBinding Light={StaticResource Slate400}, Dark={StaticResource Slate500}}"
                                                                  TextColor="{AppThemeBinding Light={StaticResource Slate900}, Dark={StaticResource Slate50}}"
                                                                  IsPassword="{Binding IsConfirmNewPasswordHidden}"
                                                                  BackgroundColor="Transparent"
                                                                  VerticalOptions="Center"
                                                                  HeightRequest="40"
                                                                  Margin="-5,0"
                                                                  ReturnType="Go"
                                                                  ReturnCommand="{Binding ResetPasswordCommand}">
                                            <controls:BorderlessEntry.Behaviors>
                                                <toolkit:EventToCommandBehavior EventName="Unfocused"
                                                                                Command="{Binding ValidatePasswordCommand}"/>
                                            </controls:BorderlessEntry.Behaviors>
                                        </controls:BorderlessEntry>
                                        <ImageButton Grid.Column="2"
                                                     Source="{Binding ConfirmNewEyeIconSource}"
                                                     Command="{Binding ToggleConfirmNewPasswordVisibilityCommand}"
                                                     HeightRequest="40"
                                                     WidthRequest="40"
                                                     BackgroundColor="Transparent"
                                                     local:CursorBehavior.Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <Button Grid.Row="5"
                                    Text="{x:Static strings:AppResources.ResetPassword}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ResetPasswordCommand}"
                                    local:CursorBehavior.Cursor="Hand"
                                    Margin="0,10,0,0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsBusy}"
                                                 Value="True">
                                        <Setter Property="Text"
                                                Value="{x:Static strings:AppResources.Saving}"/>
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                        <Setter Property="Opacity"
                                                Value="0.5"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding CanReset}"
                                                 Value="False">
                                        <Setter Property="IsEnabled"
                                                Value="False"/>
                                        <Setter Property="Opacity"
                                                Value="0.5"/>
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </Border>
                </StackLayout>
            </Grid>
        </Grid>

        <Grid InputTransparent="True"
              VerticalOptions="End"
              HorizontalOptions="End"
              Margin="0,0,30,30">
            <components:ToastView x:Name="NotificationToast"/>
        </Grid>
    </Grid>
</ContentPage>