<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="kando_desktop.Views.Components.SidebarView"
             xmlns:local="clr-namespace:kando_desktop"
             xmlns:models="clr-namespace:kando_desktop.Models"
             xmlns:strings="clr-namespace:kando_desktop.Resources.Strings"
             xmlns:converters="clr-namespace:kando_desktop.Converters"
             xmlns:vm="clr-namespace:kando_desktop.ViewModels.Components"
             x:Name="Root">

        <Border x:DataType="vm:SidebarViewModel"
                BackgroundColor="{AppThemeBinding Light=#f3f4f6, Dark=#0b111e}"
                Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#253141}"
                StrokeThickness="1">

                <Grid RowDefinitions="Auto, *, Auto">

                        <VerticalStackLayout Grid.Row="0"
                                             Spacing="0">
                                <Grid>
                                        <Grid ColumnDefinitions="Auto, Auto">
                                                <Image Grid.Column="0"
                                                       Source="kando_icon.png"
                                                       HeightRequest="40"
                                                       Aspect="AspectFit"/>

                                                <Label Grid.Column="1"
                                                       Margin="-10,0"
                                                       Text="{x:Static strings:AppResources.AppTitle}"
                                                       IsVisible="{Binding IsExpanded, Source={x:Reference Root}}"
                                                       Style="{StaticResource TitleHuge}"
                                                       FontSize="20"
                                                       VerticalOptions="Center"/>
                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="{AppThemeBinding Light=#e5e7eb, Dark=#253141}"
                                                 VerticalOptions="End"/>
                                </Grid>

                                <Grid Padding="10,15">
                                        <Border x:Name="HomeBtn"
                                                Style="{StaticResource SidebarBorderStyle}"
                                                local:CursorBehavior.Cursor="Hand">

                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border"
                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                     Value="False">
                                                                <Setter Property="HorizontalOptions"
                                                                        Value="Center"/>
                                                                <Setter Property="Padding"
                                                                        Value="10"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border"
                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                     Value="True">
                                                                <Setter Property="HorizontalOptions"
                                                                        Value="Fill"/>
                                                                <Setter Property="Padding"
                                                                        Value="15,10"/>
                                                        </DataTrigger>
                                                </Border.Triggers>

                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding NavigateToHomeCommand}"/>
                                                </Border.GestureRecognizers>

                                                <Grid ColumnDefinitions="Auto, *"
                                                      Padding="0">
                                                        <Grid.Triggers>
                                                                <DataTrigger TargetType="Grid"
                                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                             Value="False">
                                                                        <Setter Property="ColumnSpacing"
                                                                                Value="0"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Grid"
                                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                             Value="True">
                                                                        <Setter Property="ColumnSpacing"
                                                                                Value="15"/>
                                                                </DataTrigger>
                                                        </Grid.Triggers>

                                                        <Image Grid.Column="0"
                                                               Source="home.png"
                                                               HeightRequest="16"
                                                               WidthRequest="16"
                                                               VerticalOptions="Center">
                                                                <Image.Triggers>
                                                                        <DataTrigger TargetType="Image"
                                                                                     Binding="{Binding Source={x:Reference HomeBtn}, Path=BackgroundColor}"
                                                                                     Value="#e2e4e9">
                                                                                <Setter Property="Source"
                                                                                        Value="home_black.png"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Image"
                                                                                     Binding="{Binding Source={x:Reference HomeBtn}, Path=BackgroundColor}"
                                                                                     Value="#1f2937">
                                                                                <Setter Property="Source"
                                                                                        Value="home_white.png"/>
                                                                        </DataTrigger>
                                                                </Image.Triggers>
                                                        </Image>

                                                        <Label Grid.Column="1"
                                                               Text="{x:Static strings:AppResources.Home}"
                                                               FontSize="16"
                                                               VerticalOptions="Center"
                                                               IsVisible="{Binding IsExpanded, Source={x:Reference Root}}"
                                                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}">
                                                                <Label.Triggers>
                                                                        <DataTrigger TargetType="Label"
                                                                                     Binding="{Binding Source={x:Reference HomeBtn}, Path=BackgroundColor}"
                                                                                     Value="#e2e4e9">
                                                                                <Setter Property="TextColor"
                                                                                        Value="{StaticResource Slate900}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Label"
                                                                                     Binding="{Binding Source={x:Reference HomeBtn}, Path=BackgroundColor}"
                                                                                     Value="#1f2937">
                                                                                <Setter Property="TextColor"
                                                                                        Value="{StaticResource White}"/>
                                                                        </DataTrigger>
                                                                </Label.Triggers>
                                                        </Label>
                                                </Grid>
                                        </Border>
                                </Grid>

                                <Label Text="{x:Static strings:AppResources.TeamBoards}"
                                       FontSize="16"
                                       IsVisible="{Binding IsExpanded, Source={x:Reference Root}}"
                                       Margin="20,7"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#94A3B8}"/>
                        </VerticalStackLayout>

                        <ScrollView Grid.Row="1">
                                <VerticalStackLayout x:Name="BoardsList"
                                                     Margin="5,10"
                                                     Spacing="4"
                                                     BindableLayout.ItemsSource="{Binding TeamBoards}">

                                        <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:Board">

                                                        <Border Margin="0,2"
                                                                StrokeShape="RoundRectangle 12"
                                                                StrokeThickness="1"
                                                                Stroke="Transparent"
                                                                BackgroundColor="Transparent"
                                                                local:CursorBehavior.Cursor="Hand">

                                                                <Border.Triggers>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                                     Value="False">
                                                                                <Setter Property="HorizontalOptions"
                                                                                        Value="Center"/>
                                                                                <Setter Property="Padding"
                                                                                        Value="8"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                                     Value="True">
                                                                                <Setter Property="HorizontalOptions"
                                                                                        Value="Fill"/>
                                                                                <Setter Property="Padding"
                                                                                        Value="8,5"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsSelected}"
                                                                                     Value="True">
                                                                                <Setter Property="Stroke"
                                                                                        Value="{AppThemeBinding Light=#93c5fd, Dark=#334155}"/>
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="{AppThemeBinding Light=#eff6ff, Dark=#1e293b}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsSelected}"
                                                                                     Value="False">
                                                                                <Setter Property="Stroke"
                                                                                        Value="Transparent"/>
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="Transparent"/>
                                                                        </DataTrigger>
                                                                </Border.Triggers>

                                                                <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                                Command="{Binding BindingContext.SelectBoardCommand, Source={x:Reference BoardsList}}"
                                                                                CommandParameter="{Binding .}"/>
                                                                </Border.GestureRecognizers>

                                                                <Grid ColumnDefinitions="Auto, *, Auto">
                                                                        <Grid.Triggers>
                                                                                <DataTrigger TargetType="Grid"
                                                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                                             Value="False">
                                                                                        <Setter Property="ColumnSpacing"
                                                                                                Value="0"/>
                                                                                        <Setter Property="ColumnDefinitions"
                                                                                                Value="Auto, 0, 0"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger TargetType="Grid"
                                                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                                             Value="True">
                                                                                        <Setter Property="ColumnSpacing"
                                                                                                Value="12"/>
                                                                                        <Setter Property="ColumnDefinitions"
                                                                                                Value="Auto, *, Auto"/>
                                                                                </DataTrigger>
                                                                        </Grid.Triggers>

                                                                        <Border Grid.Column="0"
                                                                                WidthRequest="38"
                                                                                HeightRequest="38"
                                                                                StrokeThickness="0"
                                                                                ZIndex="-1"
                                                                                StrokeShape="RoundRectangle 12"
                                                                                BackgroundColor="{AppThemeBinding Light=#e5e7eb, Dark=#0b111e}">
                                                                                <Image Source="{Binding Icon}"
                                                                                       WidthRequest="25"
                                                                                       HeightRequest="25"
                                                                                       Aspect="AspectFit"
                                                                                       HorizontalOptions="Center"
                                                                                       VerticalOptions="Center"/>
                                                                        </Border>

                                                                        <Label Grid.Column="1"
                                                                               Text="{Binding Name}"
                                                                               VerticalOptions="Center"
                                                                               IsVisible="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                               FontSize="14"
                                                                               TextColor="{AppThemeBinding Light={StaticResource Slate700}, Dark={StaticResource Slate200}}"
                                                                               LineBreakMode="TailTruncation"/>

                                                                        <Ellipse Grid.Column="2"
                                                                                 WidthRequest="8"
                                                                                 HeightRequest="8"
                                                                                 Fill="{StaticResource Blue500}"
                                                                                 VerticalOptions="Center"
                                                                                 IsVisible="{Binding IsSelected}"/>

                                                                </Grid>
                                                        </Border>

                                                </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                        </ScrollView>

                        <VerticalStackLayout Grid.Row="2"
                                             Spacing="5">
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#e5e7eb, Dark=#253141}"
                                         VerticalOptions="Start"/>

                                <Border Style="{StaticResource MenuItemBorderStyle}"
                                        x:Name="LogoutBtn"
                                        Margin="10"
                                        local:CursorBehavior.Cursor="Hand">

                                        <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                             Value="False">
                                                        <Setter Property="HorizontalOptions"
                                                                Value="Center"/>
                                                        <Setter Property="Padding"
                                                                Value="10"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                             Value="True">
                                                        <Setter Property="HorizontalOptions"
                                                                Value="Fill"/>
                                                        <Setter Property="Padding"
                                                                Value="15,10"/>
                                                </DataTrigger>
                                        </Border.Triggers>

                                        <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto, *"
                                              Padding="0">
                                                <Grid.Triggers>
                                                        <DataTrigger TargetType="Grid"
                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                     Value="False">
                                                                <Setter Property="ColumnSpacing"
                                                                        Value="0"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Grid"
                                                                     Binding="{Binding IsExpanded, Source={x:Reference Root}}"
                                                                     Value="True">
                                                                <Setter Property="ColumnSpacing"
                                                                        Value="15"/>
                                                        </DataTrigger>
                                                </Grid.Triggers>

                                                <Image Grid.Column="0"
                                                       Source="logout_red.png"
                                                       HeightRequest="16"
                                                       WidthRequest="16"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                                        <Image.Triggers>
                                                                <DataTrigger TargetType="Image"
                                                                             Binding="{Binding Source={x:Reference LogoutBtn}, Path=BackgroundColor}"
                                                                             Value="#0b64f4">
                                                                        <Setter Property="Source"
                                                                                Value="logout_white.png"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Image"
                                                                             Binding="{Binding Source={x:Reference LogoutBtn}, Path=BackgroundColor}"
                                                                             Value="#3c83f6">
                                                                        <Setter Property="Source"
                                                                                Value="logout_black.png"/>
                                                                </DataTrigger>
                                                        </Image.Triggers>
                                                </Image>

                                                <Label Grid.Column="1"
                                                       Text="{x:Static strings:AppResources.Logout}"
                                                       IsVisible="{Binding IsExpanded, Source={x:Reference Root}}"
                                                       Style="{StaticResource MenuItemDangerLabelStyle}">
                                                        <Label.Triggers>
                                                                <DataTrigger TargetType="Label"
                                                                             Binding="{Binding Source={x:Reference LogoutBtn}, Path=BackgroundColor}"
                                                                             Value="#0b64f4">
                                                                        <Setter Property="TextColor"
                                                                                Value="White"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Label"
                                                                             Binding="{Binding Source={x:Reference LogoutBtn}, Path=BackgroundColor}"
                                                                             Value="#3c83f6">
                                                                        <Setter Property="TextColor"
                                                                                Value="Black"/>
                                                                </DataTrigger>
                                                        </Label.Triggers>
                                                </Label>
                                        </Grid>
                                </Border>
                        </VerticalStackLayout>

                </Grid>
        </Border>
</ContentView>